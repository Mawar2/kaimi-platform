# Kaimi Environment Configuration
# Copy this file to .env and fill in your actual values

# SAM.gov API Key
# Get yours at: https://open.gsa.gov/api/get-key/
SAM_API_KEY=your-sam-api-key-here

# Google AI Studio API Key (for Gemini agent platform)
# Get yours at: https://aistudio.google.com/apikey
# Project name: AI-Agent-Team
GOOGLE_AI_STUDIO_API_KEY=your-ai-studio-api-key-here

# Google Drive service-account credentials (for the Outline agent's Google Docs
# integration). Raw service-account JSON key content, same convention as SAM_API_KEY
# holding the raw key value.
GOOGLE_DRIVE_CREDENTIALS_JSON={"type":"service_account",...}

# Shared Drive ID that the Outline agent creates Docs in. Docs are created inside a
# Shared Drive (not a personal Drive) so they are owned/visible to the team rather
# than orphaned in the service account's own Drive.
GOOGLE_DRIVE_SHARED_DRIVE_ID=your-shared-drive-id-here

# GCS bucket for Zone-2 solicitation documents (raw PDFs + extracted text).
# Provisioned by scripts/setup-gcp.{sh,ps1} (issue #162). Object layout is
# {noticeID}/raw/{filename} and {noticeID}/text/{filename}.txt. The ingest stage
# (internal/ingest) reads/writes objects here.
GCS_SOLICITATIONS_BUCKET=kaimi-seeker-solicitations

# Hunter Configuration (optional - can also use command-line flags)
# MODE=cached
# NAICS_CODES=541512,541519
# STORE_PATH=./queue
