# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out

# Go workspace file
go.work

# Dependency directories
vendor/

# Build output
/bin/
/dist/

# Environment files
.env
.env.local
.env.gcp

# GCP credentials (NEVER commit these!)
sa.json
kaimi-sa-key.json
*-sa-key.json
gcp-key.json
service-account*.json
google-credentials.json
credentials.json
oauth*.json
client_secret*.json

# Local data stores (real solicitation data populated by the pipeline — never
# commit; the hosted demo pulls live from SAM.gov + GCS).
design-store/
*-store/
/store/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Pulse-specific
/queue/*.json
!/queue/.gitkeep

# Wails desktop build output — regenerated by `wails build` (default icon/
# manifest are placeholders; branded build assets are added in a later ticket).
cmd/desktop/build/
# Wails-generated JS runtime/bindings — regenerated by `wails build`/`wails dev`.
cmd/desktop/frontend/wailsjs/
# Frontend deps + Vite build output (regenerated by `wails build`).
cmd/desktop/frontend/node_modules/
cmd/desktop/frontend/dist/
# Stray dev binary from `go build ./cmd/desktop` cross-compiles (non-.exe)
/desktop

# Wails frontend-install hash (generated)
cmd/desktop/frontend/package.json.md5

# gstack local artifacts (browse logs, audit) — never commit
.gstack/
