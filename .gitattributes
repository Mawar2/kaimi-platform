# Force LF for files whose toolchains require it. Without this, Windows
# checkouts (core.autocrlf=true) get CRLF working copies, which gofmt /
# golangci-lint flag on every .go file — local QA gates then fail on a clean
# clone even though Linux CI is green.
*.go text eol=lf
go.mod text eol=lf
go.sum text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
# Shell scripts must stay LF: a CRLF shebang line breaks execution under bash
# (e.g. scripts/provision-customer.sh, deploy/scripts/*.sh) on Linux/macOS/CI.
*.sh text eol=lf
